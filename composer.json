{
    "name": "allanzico/laravel-helios",
    "description": "A lightweight, self-hosted monitoring tool for Laravel applications with real-time tracking of logs, jobs, queries, and performance.",
    "type": "library",
    "keywords": ["laravel", "monitoring", "performance", "logs", "jobs", "queries", "health-checks", "helios"],
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Allan Akanyijuka",
            "email": "akanyijuka@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "symfony/process": "^7.0|^8.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Allanzico\\LaravelHelios\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Allanzico\\LaravelHelios\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Allanzico\\LaravelHelios\\HeliosServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
